{
    "elements": [
        {
            "type": "ValidationTextBox",
            "name": "Host",
            "caption": "Lokale IP des Geräts (feste IP in der Fritzbox empfohlen)"
        },
        {
            "type": "Select",
            "name": "DeviceType",
            "caption": "Gerätetyp",
            "options": [
                { "caption": "MSS210P – Steckdose (1 Kanal)", "value": "mss210p" },
                { "caption": "MSS620 – Doppelsteckdose (2 Kanäle)", "value": "mss620" },
                { "caption": "Steckdose / Schalter – allgemein (ToggleX)", "value": "plug" },
                { "caption": "Mehrfachsteckdose / Steckdosenleiste (Kanäle automatisch)", "value": "strip" },
                { "caption": "MRS100 – Rollladen", "value": "mrs100" },
                { "caption": "Lampe / Dimmer / LED (MSL-Serie, MSS560)", "value": "light" },
                { "caption": "Garagentoröffner (MSG100 / MSG200)", "value": "garage" },
                { "caption": "Hub MSH300 (Sensoren + Thermostat-Ventile)", "value": "hub" },
                { "caption": "WLAN-Thermostat (MTS200 / MTS215B / MTS960)", "value": "thermostat" }
            ]
        },
        {
            "type": "ValidationTextBox",
            "name": "DeviceName",
            "caption": "Name"
        },
        {
            "type": "PasswordTextBox",
            "name": "Key",
            "caption": "Konto-Key (wird beim Hinzufügen aus der Cloud automatisch gesetzt)"
        },
        {
            "type": "NumberSpinner",
            "name": "PollInterval",
            "caption": "Status alle … Sekunden abfragen (0 = aus, Standard 3)",
            "suffix": "s"
        },
        {
            "type": "Select",
            "name": "VisuTheme",
            "caption": "Kachel-Darstellung",
            "options": [
                { "caption": "Automatisch (System)", "value": "auto" },
                { "caption": "Hell", "value": "light" },
                { "caption": "Dunkel", "value": "dark" }
            ]
        }
    ],
    "actions": [
        {
            "type": "Button",
            "caption": "Status jetzt abrufen",
            "onClick": "MERO_Update($id);"
        }
    ],
    "status": [
        { "code": 101, "icon": "inactive", "caption": "Erstellt" },
        { "code": 102, "icon": "active", "caption": "Aktiv" },
        { "code": 201, "icon": "error", "caption": "Gerät lokal nicht erreichbar" },
        { "code": 202, "icon": "error", "caption": "Kein Konto-Key / keine IP gesetzt" }
    ]
}
